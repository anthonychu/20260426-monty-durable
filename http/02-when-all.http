# when_all fan-out/fan-in scenarios
#
# Prereqs:
# 1. Start Azurite and the Durable Task Scheduler emulator.
# 2. Start the Functions host from this workspace: `source .venv/bin/activate && func start`.
# 3. For Azure REST scenarios, run `az login` and make sure `@subscriptionId` is set below.
#
# `when_all` is implemented in the Monty prelude with `asyncio.gather`.
# The bridge sees the pending Monty futures and yields Durable `task_all` under the hood.

@baseUrl = http://localhost:7071
@orchestrator = monty_orchestrator
@subscriptionId = ef6e1243-d48a-417e-8e6d-40cd96e110fd

### Start: local echo fan-out/fan-in
# Run this first if you want a no-Azure smoke test.
# It schedules three local `echo` activities and waits for all of them.
# @name startWhenAllEcho
POST {{baseUrl}}/api/orchestrators/{{orchestrator}}
Content-Type: application/json

{
  "code": "tasks = [call_activity(\"echo\", {\"i\": 1}), call_activity(\"echo\", {\"i\": 2}), call_activity(\"echo\", {\"i\": 3})]\nresults = await when_all(tasks)\nresults"
}

### Status: local echo fan-out/fan-in
# Run after `Start: local echo fan-out/fan-in`.
# Expected: output.output is the three echo payloads and metadata.scheduledActivities is 3.
GET {{startWhenAllEcho.response.body.statusQueryGetUri}}

### Start: Azure REST list Function Apps
# Run this after Azure auth is configured.
# It uses the read-only `azure_rest` activity to list Function App resources in the subscription.
# @name startListFunctionApps
POST {{baseUrl}}/api/orchestrators/{{orchestrator}}
Content-Type: application/json

{
  "code": "apps = await call_activity(\"azure_rest\", {\"path\": \"/subscriptions/{{subscriptionId}}/resources?api-version=2021-04-01\", \"query\": \"value[?type=='Microsoft.Web/sites' && contains(kind, 'functionapp')].{name:name, id:id, resourceGroup:resourceGroup, location:location, kind:kind}\"})\napps"
}

### Status: Azure REST list Function Apps
# Run after `Start: Azure REST list Function Apps`.
# Expected: output.output is an array of Function App summaries.
GET {{startListFunctionApps.response.body.statusQueryGetUri}}

### Start: Azure REST Function Apps detail fan-out
# Run this after Azure auth is configured.
# It lists Function Apps, creates one detail activity per app, then awaits all detail calls together.
# @name startFunctionAppDetails
POST {{baseUrl}}/api/orchestrators/{{orchestrator}}
Content-Type: application/json

{
  "code": "apps = await call_activity(\"azure_rest\", {\"path\": \"/subscriptions/{{subscriptionId}}/resources?api-version=2021-04-01\", \"query\": \"value[?type=='Microsoft.Web/sites' && contains(kind, 'functionapp')].{name:name, id:id, resourceGroup:resourceGroup, location:location}\"})\ntasks = [call_activity(\"azure_rest\", {\"path\": app[\"id\"] + \"?api-version=2022-03-01\", \"query\": \"{name:name, location:location, state:properties.state, defaultHostName:properties.defaultHostName, httpsOnly:properties.httpsOnly}\"}) for app in apps]\ndetails = await when_all(tasks)\ndetails"
}

### Status: Azure REST Function Apps detail fan-out
# Run after `Start: Azure REST Function Apps detail fan-out`.
# Expected: output.output is one detail object per Function App.
GET {{startFunctionAppDetails.response.body.statusQueryGetUri}}
